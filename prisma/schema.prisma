generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CREATOR
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum LaunchType {
  LIVE
  PREORDER
}

enum SaleCategory {
  READY
  PREORDER
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String?
  role      Role       @default(CUSTOMER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  accounts      Account[]
  products      Product[]
  orders        Order[]
  cart          Cart[]
  passwordResets PasswordResetToken[]
  ratings        Rating[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Product {
  id          String        @id @default(cuid())
  creatorId   String
  title       String
  description String        @db.Text
  price       Float
  images      String[]
  status      ProductStatus @default(PENDING)
  category    String        @default("General")

  saleCategory  SaleCategory @default(READY)

  problemStatement String? @db.Text
  usp              String? @db.Text
  founderName      String?
  teamDescription  String? @db.Text
  creatorStory     String? @db.Text

  estimatedCompletion DateTime?
  fundingGoal         Float?
  currentFunding      Float?    @default(0)
  launchDate          DateTime?
  preorderPrice       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User    @relation(fields: [creatorId], references: [id])
  orders  Order[]
  cart    Cart[]
  ratings Rating[]

  @@index([status])
  @@index([creatorId])
  @@index([category])
  @@index([saleCategory])
}

model Order {
  id                String        @id @default(cuid())
  userId            String
  productId         String
  creatorId         String
  totalAmount       Float
  platformFee       Float
  creatorEarnings   Float
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  createdAt         DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([creatorId])
  @@index([paymentStatus])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}

model Launch {
  id                 String     @id @default(cuid())
  productName        String
  creatorName        String
  creatorDescription String     @db.Text
  productDescription String     @db.Text
  usp                String     @db.Text
  problemStatement   String     @db.Text
  price              Float
  images             String[]
  launchType         LaunchType @default(LIVE)
  isPublished        Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([isPublished])
  @@index([launchType])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}
